# Kafka / Redpanda
KAFKA_BROKERS=broker:9092

# Storage backend: "minio" (default, local) or "gcs" (cloud)
STORAGE_BACKEND=minio

# MinIO (local GCS proxy)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kappa-lake

# GCS (only used when STORAGE_BACKEND=gcs)
GCS_BUCKET=
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# Nessie REST catalog
NESSIE_URI=http://nessie:19120/api/v1

# PostgreSQL serving layer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kappa
POSTGRES_USER=kappa
POSTGRES_PASSWORD=kappa
POSTGRES_DSN=postgresql://kappa:kappa@postgres:5432/kappa

# Flink
FLINK_JOBMANAGER_HOST=jobmanager
FLINK_JOBMANAGER_PORT=8081
FLINK_CHECKPOINT_INTERVAL_MS=30000

# Simulator
SIMULATOR_RATE=10
SIMULATOR_TOPIC=raw-events
SIMULATOR_ENTITY_TOPIC=entity-updates
