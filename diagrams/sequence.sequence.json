  "cards": [
    {
      "dot": "emerald",
      "title": "Happy Path",
      "items": [
        "Analyst -> Cube.js -> Doris -> data source -> response",
        "Cube.js's own pre-aggregation cache is checked before any live query",
        "Return messages are quieter than forward calls"
      ]
    },
    {
      "dot": "rose",
      "title": "Cache Fallback",
      "items": [
        "A pre-aggregation miss forces a live federated query",
        "Doris queries the Iceberg lakehouse catalog and the Postgres JDBC catalog in one session",
        "Both catalogs are read before Doris returns a single joined result"
      ]
    },
    {
      "dot": "orange",
      "title": "Timing",
      "items": [
        "The Iceberg scan reads a consistent snapshot via the Nessie REST catalog",
        "Cube.js persists the new pre-aggregation so the next matching query is a cache hit",
        "Analyst-facing latency includes both catalog round-trips on a miss"
      ]
    }
  ]
}
