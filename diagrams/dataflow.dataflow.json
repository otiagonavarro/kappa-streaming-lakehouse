{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Bronze → Silver → Gold Data Flow",
    "subtitle": "Clickstream + entity lineage, user-identifier sensitivity, and downstream consumers",
    "output": "dataflow.html",
    "viewBox": [1080, 760]
  },
  "stages": [
    { "label": "Sources" },
    { "label": "Bronze" },
    { "label": "Silver" },
    { "label": "Gold" },
    { "label": "Consumers" }
  ],
  "nodes": [
    { "id": "kafka_raw", "type": "messagebus", "label": "raw-events", "sublabel": "Kafka topic", "stage": 0, "row": 0, "tag": "clickstream" },
    { "id": "kafka_entity", "type": "messagebus", "label": "entity-updates", "sublabel": "Kafka topic", "stage": 0, "row": 3, "tag": "CDC" },

    { "id": "bronze_events", "type": "database", "label": "bronze.raw_events", "sublabel": "Iceberg, immutable", "stage": 1, "row": 0, "width": 140, "tag": "as-is" },
    { "id": "entity_sync", "type": "backend", "label": "Entity + Order Sync", "sublabel": "PyFlink job", "stage": 1, "row": 3, "width": 130 },

    { "id": "silver_events", "type": "database", "label": "silver.validated_events", "sublabel": "Iceberg, cleaned", "stage": 2, "row": 0, "width": 150 },
    { "id": "silver_sessions", "type": "database", "label": "silver.user_sessions", "sublabel": "Iceberg, 30m gap", "stage": 2, "row": 1, "width": 150 },
    { "id": "pg_dims", "type": "database", "label": "Dimension + Fact Tables", "sublabel": "Iceberg + Postgres", "stage": 2, "row": 3, "width": 150, "tag": "serving" },

    { "id": "gold_user360", "type": "database", "label": "gold.user_360", "sublabel": "Iceberg, lifetime KPIs", "stage": 3, "row": 0, "width": 140 },
    { "id": "gold_session", "type": "database", "label": "gold.session_metrics", "sublabel": "Iceberg + Postgres", "stage": 3, "row": 1, "width": 150 },
    { "id": "gold_funnel", "type": "database", "label": "gold.product_funnel_1m", "sublabel": "Postgres, 1m windows", "stage": 3, "row": 2, "width": 155 },

    { "id": "doris", "type": "backend", "label": "Doris", "sublabel": "iceberg + jdbc federation", "stage": 4, "row": 1 },
    { "id": "cube", "type": "backend", "label": "Cube.js", "sublabel": "semantic layer", "stage": 4, "row": 2 },
    { "id": "bi", "type": "external", "label": "BI / Analysts", "sublabel": "dashboards, DuckDB", "stage": 4, "row": 3, "width": 130 }
  ],
  "flows": [
    { "from": "kafka_raw", "to": "bronze_events", "label": "raw clickstream", "classification": "as-ingested", "variant": "emphasis" },
    { "from": "bronze_events", "to": "silver_events", "label": "clean + normalize", "classification": "user-identifier", "variant": "security", "labelDy": 53 },
    { "from": "silver_events", "to": "silver_sessions", "label": "sessionize", "classification": "user-identifier", "variant": "security" },
    { "from": "silver_sessions", "to": "gold_session", "label": "session KPIs", "classification": "user-identifier", "variant": "security", "labelDy": 53 },
    { "from": "gold_session", "to": "gold_user360", "label": "lifetime rollup", "classification": "user-identifier", "variant": "dashed", "route": "straight", "fromSide": "top", "toSide": "bottom", "labelDy": 82 },
    { "from": "kafka_raw", "to": "gold_funnel", "label": "1-min tumbling counts", "classification": "non-PII", "variant": "default", "labelDy": 53 },
    { "from": "kafka_entity", "to": "entity_sync", "label": "categories · users · products", "classification": "CDC", "variant": "emphasis", "labelDy": 53 },
    { "from": "entity_sync", "to": "pg_dims", "label": "dual-sink write", "classification": "durable + serving", "variant": "default", "labelDy": 53 },
    { "from": "gold_session", "to": "doris", "label": "iceberg federation", "classification": "read-only", "variant": "emphasis", "labelDy": 53 },
    { "from": "pg_dims", "to": "doris", "label": "jdbc federation", "classification": "read-only", "variant": "default", "labelDy": 53 },
    { "from": "doris", "to": "cube", "label": "gold schema", "classification": "approved only", "variant": "emphasis" },
    { "from": "cube", "to": "bi", "label": "REST / SQL API", "classification": "aggregated", "variant": "emphasis" },
    { "from": "pg_dims", "to": "bi", "label": "sub-10ms reads", "classification": "read-only", "variant": "dashed" }
  ],
  "cards": [
    {
      "dot": "emerald",
      "title": "Primary Data Path",
      "items": [
        "Events move left to right through bronze, silver, and gold layers",
        "Each ODCS contract owns one layer transition — the job is a generic executor of its YAML contract",
        "Doris federates gold Iceberg tables and Postgres serving tables without re-ingestion"
      ]
    },
    {
      "dot": "rose",
      "title": "Sensitivity Boundary",
      "items": [
        "user_id carries a governance:dimension / user-identifier tag from bronze through gold",
        "Every hop that carries user_id is styled as a security flow",
        "Product-level funnel counts stay non-PII and never touch user_id"
      ]
    },
    {
      "dot": "orange",
      "title": "Downstream Consumers",
      "items": [
        "product_funnel_1m reads Kafka directly, bypassing bronze/silver validation for lower latency",
        "Cube.js exposes the approved gold schema only, not raw silver/bronze tables",
        "Analysts can also read Postgres serving tables directly for sub-10ms dashboards"
      ]
    }
  ]
}
